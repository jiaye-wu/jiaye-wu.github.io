{% assign lang = site.active_lang | split: '-' | first %}
{% if lang == 'pt' %}
  {% assign lang = site.active_lang %}
{% endif %}
{% if site.active_lang == 'zh-cn' or site.active_lang == 'zh-sg' or site.active_lang == 'zh-my' or site.active_lang == 'zh-hans' %}
  {% assign lang = 'cn' %}
{% endif %}
{% if site.active_lang == 'zh-tw' or site.active_lang == 'zh-hk' or site.active_lang == 'zh-mo' or site.active_lang == 'zh-hant' %}
  {% assign lang = 'zh-tw' %}
{% endif %}

<div class="repo p-2 text-center">
  <a href="https://github.com/{{ include.username }}">
    {% comment %} available locales: https://github.com/anuraghazra/github-readme-stats?tab=readme-ov-file#available-locales {% endcomment %}
    <img
      class="only-light w-100"
      alt="{{ include.username }}"
      src="https://github-readme-stats.vercel.app/api/?username={{ include.username }}&theme={{ site.repo_theme_light }}&locale={{ lang }}&show_icons=true"
    >
    <img
      class="only-dark w-100"
      alt="{{ include.username }}"
      src="https://github-readme-stats.vercel.app/api/?username={{ include.username }}&theme={{ site.repo_theme_dark }}&locale={{ lang }}&show_icons=true"
    >
  </a>
</div>
