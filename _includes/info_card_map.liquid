<div class="card mt-3">
  <div class="p-3">
    <div class="row">
      <div class="col-sm-10"> 
        <h5 id="{{ include.name | slugify }}" class="card-title"><strong>{{ include.name }}</strong></h5>
        <h6 class="card-subtitle font-italic">{{ include.role }}</h6>
      </div>
      <div class="col-sm-2 text-sm-right">
        <span class="badge">
          {{ include.badge }}
        </span>
      </div>
    </div>
    <ul class="card-text font-weight-light list-group list-group-flush">
      <li class="list-group-item">
        <div class="row">
          <div class="col-sm-6">
            {% comment %} <p>{{ include.description }}</p> {% endcomment %}
             {{ include.description | markdownify }}
          </div>          
          <div class="col-sm-6">
            <img src="{{ include.image }}" style="max-width: 100%; max-height: 600px; height: auto; width: auto;">
          </div>
        </div>
      </li>
    </ul>
  </div>
</div>